Bootstrap: docker
From: ubuntu:22.04

# traincraft-dft — FHI-aims DFT labeling image (slim, fully open toolchain).
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ FHI-aims academic license (MS1P e.V.) is free for academic groups with a │
# │ voluntary donation; the source is obtained by registration. It is NOT     │
# │ committed to this repo and should not be publicly redistributed — supply  │
# │ it at build time via --build-arg AIMS_SRC=/path/to/fhi-aims.tar.gz, and   │
# │ keep the resulting .sif off public registries.                           │
# │ (Prefer fully open source? Use traincraft-qe.def — Quantum ESPRESSO.)     │
# └─────────────────────────────────────────────────────────────────────────┘
#
# This is the SMALL FHI-aims image (~400 MB vs ~4 GB for the MKL build): it is
# compiled with the open toolchain — gfortran + OpenBLAS + source-built ScaLAPACK
# — exactly like traincraft-qe, so nothing but the binary and a few runtime .so's
# ship in the image. FHI-aims runs its heavy eigensolves through ELPA (bundled via
# ELSI), so the OpenBLAS-vs-MKL gap is modest for this code. If you want maximum
# Intel-CPU throughput instead, build traincraft-dft-mkl.def (oneAPI MKL, larger).
#
# Contents: only FHI-aims (aims.x) + species_defaults. No Python, no traincraft —
# a bare MPI worker. traincraft-core (ASE FileIOCalculator) writes
# control.in/geometry.in and parses aims.out around
# `srun --mpi=pmix apptainer exec traincraft-dft.sif aims.x`.
#
# MPI model (self-contained, PMIx launch — same as traincraft-qe):
#   srun --mpi=pmix apptainer exec traincraft-dft.sif aims.x
# OpenMPI is built against UCX (interconnect) and PMIx (so Slurm's slurmstepd does
# the wire-up — NO host MPI needed). On Cray/Slingshot (LUMI: no pmix) prefer
# runtime="native" with the site's FHI-aims module — see docs/how-to/hpc.md.

%arguments
    AIMS_SRC=fhi-aims.tar.gz
    UCX_VERSION=1.17.0
    PMIX_VERSION=5.0.3
    OPENMPI_VERSION=5.0.5
    SCALAPACK_VERSION=2.2.0
    # Parallel build width. Defaults to nproc; override (--build-arg BUILD_JOBS=N)
    # on shared build nodes where nproc under-reports the cgroup CPU quota.
    BUILD_JOBS=

%files
    {{ AIMS_SRC }} /opt/aims-src.tar.gz

%post
    set -eux
    jobs="{{ BUILD_JOBS }}"; jobs="${jobs:-$(nproc)}"   # parallel build width
    export DEBIAN_FRONTEND=noninteractive
    apt-get update && apt-get install -y --no-install-recommends \
        build-essential gfortran cmake make git wget ca-certificates file pkg-config \
        python3 libopenblas-dev \
        libevent-dev libhwloc-dev zlib1g-dev \
        librdmacm-dev libibverbs-dev libnuma-dev
    rm -rf /var/lib/apt/lists/*

    # Harden every download below against transient network blips (a single failed
    # wget should not throw away a 30-minute build — HPC build nodes are flaky).
    printf 'tries=5\nwaitretry=15\ntimeout=30\nretry_connrefused=on\n' > /etc/wgetrc

    # TODO(site): add -march=native (or the cluster's arch, e.g. -march=sapphirerapids
    # / -march=znver3) once you know the target CPU. The whole point of compiling from
    # source is this tuning; a generic conda build is exactly what we are avoiding.
    export CFLAGS="-O3" FCFLAGS="-O3" FFLAGS="-O3"

    cd /tmp

    # Each ./configure / make / make install is on its OWN line: chaining with `&&`
    # masks failures (set -e is suppressed for a non-final command in an && list).
    # PMIx + OpenMPI use the system libevent + hwloc — OpenMPI refuses an external
    # PMIx alongside its internal libevent/hwloc, so all three must be external.
    # --- UCX: RDMA transport for the interconnect -------------------------------
    wget -q https://github.com/openucx/ucx/releases/download/v{{ UCX_VERSION }}/ucx-{{ UCX_VERSION }}.tar.gz
    tar xf ucx-{{ UCX_VERSION }}.tar.gz
    cd ucx-{{ UCX_VERSION }}
    ./configure --prefix=/opt/ucx --enable-optimizations --disable-logging \
        --disable-debug --without-go --without-java
    make -j"$jobs"
    make install
    cd /tmp && rm -rf ucx-{{ UCX_VERSION }}*

    # --- PMIx: process wire-up, matched to Slurm's PMIx server ------------------
    wget -q https://github.com/openpmix/openpmix/releases/download/v{{ PMIX_VERSION }}/pmix-{{ PMIX_VERSION }}.tar.gz
    tar xf pmix-{{ PMIX_VERSION }}.tar.gz
    cd pmix-{{ PMIX_VERSION }}
    ./configure --prefix=/opt/pmix
    make -j"$jobs"
    make install
    cd /tmp && rm -rf pmix-{{ PMIX_VERSION }}*

    # --- OpenMPI: built against UCX + PMIx, launchable by `srun --mpi=pmix` ------
    wget -q https://download.open-mpi.org/release/open-mpi/v5.0/openmpi-{{ OPENMPI_VERSION }}.tar.gz
    tar xf openmpi-{{ OPENMPI_VERSION }}.tar.gz
    cd openmpi-{{ OPENMPI_VERSION }}
    ./configure --prefix=/opt/openmpi \
        --with-ucx=/opt/ucx \
        --with-pmix=/opt/pmix \
        --with-libevent=external --with-hwloc=external \
        --with-slurm \
        --enable-mca-no-build=btl-uct
    make -j"$jobs"
    make install
    cd /tmp && rm -rf openmpi-{{ OPENMPI_VERSION }}*
    export PATH=/opt/openmpi/bin:$PATH
    export LD_LIBRARY_PATH=/opt/openmpi/lib:/opt/ucx/lib:/opt/pmix/lib

    # --- ScaLAPACK: built from source against THIS OpenMPI + OpenBLAS -----------
    # Not the distro libscalapack-openmpi-dev: that one is linked against Ubuntu's
    # OpenMPI (4.1), not our /opt/openmpi (5.0) — an ABI mismatch that FHI-aims'
    # heavy BLACS/ScaLAPACK use would expose. Build it ourselves (ScaLAPACK >=2.0
    # bundles BLACS, so this is the whole stack) so the MPI ABI matches exactly.
    # gfortran >= 10 needs -fallow-argument-mismatch for BLACS' legacy MPI calls.
    wget -q -O scalapack.tar.gz https://github.com/Reference-ScaLAPACK/scalapack/archive/refs/tags/v{{ SCALAPACK_VERSION }}.tar.gz
    tar xf scalapack.tar.gz
    cd scalapack-{{ SCALAPACK_VERSION }}
    mkdir build && cd build
    cmake -DCMAKE_INSTALL_PREFIX=/opt/scalapack \
          -DBUILD_SHARED_LIBS=ON \
          -DCMAKE_C_COMPILER=mpicc \
          -DCMAKE_Fortran_COMPILER=mpifort \
          -DCMAKE_Fortran_FLAGS="-O3 -fallow-argument-mismatch" \
          -DBLAS_LIBRARIES=/usr/lib/x86_64-linux-gnu/libopenblas.so \
          -DLAPACK_LIBRARIES=/usr/lib/x86_64-linux-gnu/libopenblas.so \
          ..
    make -j"$jobs"
    make install
    cd /tmp && rm -rf scalapack-{{ SCALAPACK_VERSION }} scalapack.tar.gz

    # --- FHI-aims: gfortran + OpenBLAS + our ScaLAPACK, ELPA via bundled ELSI ----
    # AIMS_SRC must be a tarball with exactly ONE top-level dir (--strip-components=1
    # drops it) AND must include FHI-aims' submodules — ELSI is required to build:
    #   git -C FHIaims submodule update --init --recursive
    #   tar czf s.tgz -C <parent> FHIaims --exclude-vcs
    mkdir -p /opt/aims && tar -xf /opt/aims-src.tar.gz -C /opt/aims --strip-components=1
    # FHI-aims' cmake runs `git submodule update` only if a top-level .git exists,
    # and that git call fails under the build's fakeroot. We ship the submodule
    # SOURCE in the tarball, so drop any .git and let cmake use it directly.
    rm -rf /opt/aims/.git
    cd /opt/aims && mkdir -p build && cd build

    # gfortran needs -ffree-line-length-none (FHI-aims has long lines) and, like
    # ScaLAPACK/QE, -fallow-argument-mismatch for the bundled legacy MPI calls.
    # ELSI is added in-tree (add_subdirectory), so it inherits these flags. PBE and
    # the other functionals are FHI-aims-internal — no external libxc needed.
    cmake -DCMAKE_Fortran_COMPILER=mpifort \
          -DCMAKE_C_COMPILER=mpicc \
          -DCMAKE_CXX_COMPILER=mpicxx \
          -DCMAKE_Fortran_FLAGS="-O3 -ffree-line-length-none -fallow-argument-mismatch" \
          -DCMAKE_C_FLAGS="-O3" \
          -DUSE_MPI=ON \
          -DUSE_SCALAPACK=ON \
          -DLIB_PATHS="/opt/scalapack/lib;/usr/lib/x86_64-linux-gnu" \
          -DLIBS="scalapack;openblas" \
          -DCMAKE_BUILD_TYPE=Release \
          -DTARGET_NAME=aims.x \
          ..
    # The cmake executable target is 'aims'; -DTARGET_NAME=aims.x just names the
    # output binary aims.x. (There is no make target literally called 'aims.x'.)
    make -j"$jobs" aims

    install -d /opt/aims/bin
    cp /opt/aims/build/aims.x /opt/aims/bin/aims.x
    # species_defaults ship with the source tree; keep them discoverable.
    ln -s /opt/aims/species_defaults /opt/aims/bin/species_defaults || true

    rm -f /opt/aims-src.tar.gz

%environment
    export PATH=/opt/aims/bin:/opt/openmpi/bin:/opt/pmix/bin:$PATH
    export LD_LIBRARY_PATH=/opt/aims/bin:/opt/scalapack/lib:/opt/openmpi/lib:/opt/ucx/lib:/opt/pmix/lib:$LD_LIBRARY_PATH
    export AIMS_SPECIES_DIR=/opt/aims/species_defaults

%runscript
    exec aims.x "$@"

%labels
    org.traincraft.image dft
    org.traincraft.target cpu-mpi-pmix
    org.traincraft.toolchain gfortran-openblas
    org.traincraft.license fhi-aims-private

%help
    FHI-aims worker (slim, gfortran + OpenBLAS + source ScaLAPACK; compiled from
    your private source). Self-contained OpenMPI+UCX+PMIx — launch with Slurm's
    PMIx, no host MPI needed:
      srun --mpi=pmix apptainer exec --bind "$SCRATCH" traincraft-dft.sif aims.x
    Inputs (control.in/geometry.in) are prepared, and aims.out parsed, by
    traincraft-core via its dft.py FileIOCalculator (TRAINCRAFT_AIMS_COMMAND).

    REQUIRED at run time: FHI-aims aborts with "stacksize too low" unless the
    job sets `ulimit -s unlimited` (and ideally `export OMP_STACKSIZE=64M`).
    Put that in your Slurm pre_commands.

    For maximum Intel-CPU throughput, build traincraft-dft-mkl.def instead (MKL,
    ~4 GB). Both produce identical physics; this image just trades a little BLAS
    speed for ~10x smaller size and a fully open toolchain.
