Bootstrap: docker
From: intel/oneapi-hpckit:2024.2.1-devel-ubuntu22.04

# traincraft-dft — FHI-aims DFT labeling image (the reference engine).
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ FHI-aims academic license (MS1P e.V.) is free for academic groups with a │
# │ voluntary donation; the source is obtained by registration. It is NOT     │
# │ committed to this repo and should not be publicly redistributed — supply  │
# │ it at build time via --build-arg AIMS_SRC=/path/to/fhi-aims.tar.gz, and   │
# │ keep the resulting .sif off public registries.                           │
# │ (Prefer fully open source? Use traincraft-qe.def — Quantum ESPRESSO.)     │
# └─────────────────────────────────────────────────────────────────────────┘
#
# Contents: only FHI-aims (aims.x) compiled with MKL + ScaLAPACK against a
# source-built OpenMPI+UCX+PMIx stack, plus species_defaults. No Python, no
# traincraft — it is a bare MPI worker. traincraft-core (ASE FileIOCalculator)
# writes control.in/geometry.in and parses aims.out around
# `srun --mpi=pmix apptainer exec traincraft-dft.sif aims.x`.
#
# MPI model (self-contained, PMIx launch — same as traincraft-qe):
#   srun --mpi=pmix apptainer exec traincraft-dft.sif aims.x
# OpenMPI is built against UCX (interconnect) and PMIx (so Slurm's slurmstepd does
# the wire-up — NO host MPI needed). MKL provides the math; ScaLAPACK uses MKL's
# *OpenMPI* BLACS (libmkl_blacs_openmpi_lp64), so we keep MKL performance without
# Intel MPI. This makes the image uniform with the QE image (one launch model, one
# set of binds). On Cray/Slingshot (LUMI: no pmix) prefer runtime="native" with
# the site's FHI-aims module instead of this image — see docs/how-to/hpc.md.

%arguments
    AIMS_SRC=fhi-aims.tar.gz
    UCX_VERSION=1.17.0
    PMIX_VERSION=5.0.3
    OPENMPI_VERSION=5.0.5

%files
    {{ AIMS_SRC }} /opt/aims-src.tar.gz

%post
    set -eux
    apt-get update && apt-get install -y --no-install-recommends \
        cmake make git wget ca-certificates \
        librdmacm-dev libibverbs-dev libnuma-dev
    rm -rf /var/lib/apt/lists/*

    source /opt/intel/oneapi/setvars.sh   # MKL + icx/ifx

    # TODO(site): add the target arch (e.g. -xSAPPHIRERAPIDS for Leonardo DCGP) to
    # the FHI-aims flags below; tuning for the CPU is the reason we compile.
    cd /tmp

    # --- UCX + PMIx + OpenMPI (built with the Intel compilers, same as QE) -------
    wget -q https://github.com/openucx/ucx/releases/download/v{{ UCX_VERSION }}/ucx-{{ UCX_VERSION }}.tar.gz
    tar xf ucx-{{ UCX_VERSION }}.tar.gz && cd ucx-{{ UCX_VERSION }}
    ./configure --prefix=/opt/ucx --enable-optimizations --disable-logging --disable-debug
    make -j"$(nproc)" && make install
    cd /tmp && rm -rf ucx-{{ UCX_VERSION }}*

    wget -q https://github.com/openpmix/openpmix/releases/download/v{{ PMIX_VERSION }}/pmix-{{ PMIX_VERSION }}.tar.gz
    tar xf pmix-{{ PMIX_VERSION }}.tar.gz && cd pmix-{{ PMIX_VERSION }}
    ./configure --prefix=/opt/pmix && make -j"$(nproc)" && make install
    cd /tmp && rm -rf pmix-{{ PMIX_VERSION }}*

    wget -q https://download.open-mpi.org/release/open-mpi/v5.0/openmpi-{{ OPENMPI_VERSION }}.tar.gz
    tar xf openmpi-{{ OPENMPI_VERSION }}.tar.gz && cd openmpi-{{ OPENMPI_VERSION }}
    CC=icx FC=ifx ./configure --prefix=/opt/openmpi \
        --with-ucx=/opt/ucx --with-pmix=/opt/pmix --with-slurm
    make -j"$(nproc)" && make install
    cd /tmp && rm -rf openmpi-{{ OPENMPI_VERSION }}*
    export PATH=/opt/openmpi/bin:$PATH
    export LD_LIBRARY_PATH=/opt/openmpi/lib:/opt/ucx/lib:/opt/pmix/lib:$LD_LIBRARY_PATH

    # --- FHI-aims: MKL + ScaLAPACK over OpenMPI BLACS ---------------------------
    mkdir -p /opt/aims && tar -xf /opt/aims-src.tar.gz -C /opt/aims --strip-components=1
    cd /opt/aims && mkdir -p build && cd build

    # TODO(site): confirm the MKL ScaLAPACK/BLACS link line for your MKL version.
    # The key choice is the *OpenMPI* BLACS (libmkl_blacs_openmpi_lp64), NOT the
    # Intel-MPI one, since our MPI is OpenMPI. Enable DFPT for polarizability.
    cmake -DCMAKE_Fortran_COMPILER=mpifort \
          -DCMAKE_C_COMPILER=mpicc \
          -DUSE_MPI=ON \
          -DUSE_SCALAPACK=ON \
          -DLIB_PATHS="$MKLROOT/lib/intel64" \
          -DLIBS="mkl_scalapack_lp64 mkl_intel_lp64 mkl_sequential mkl_core mkl_blacs_openmpi_lp64" \
          -DCMAKE_BUILD_TYPE=Release \
          ..
    make -j"$(nproc)" aims.x

    install -d /opt/aims/bin
    cp /opt/aims/build/aims.x /opt/aims/bin/aims.x
    # species_defaults ship with the source tree; keep them discoverable.
    ln -s /opt/aims/species_defaults /opt/aims/bin/species_defaults || true

    rm -f /opt/aims-src.tar.gz

%environment
    export PATH=/opt/aims/bin:/opt/openmpi/bin:/opt/pmix/bin:$PATH
    export LD_LIBRARY_PATH=/opt/openmpi/lib:/opt/ucx/lib:/opt/pmix/lib:$LD_LIBRARY_PATH
    export AIMS_SPECIES_DIR=/opt/aims/species_defaults

%runscript
    exec aims.x "$@"

%labels
    org.traincraft.image dft
    org.traincraft.target cpu-mpi-pmix
    org.traincraft.license fhi-aims-private

%help
    FHI-aims worker (compiled from your private source). Self-contained
    OpenMPI+UCX+PMIx — launch with Slurm's PMIx, no host MPI needed:
      srun --mpi=pmix apptainer exec --bind "$SCRATCH" traincraft-dft.sif aims.x
    Inputs (control.in/geometry.in) are prepared, and aims.out parsed, by
    traincraft-core via its dft.py FileIOCalculator (TRAINCRAFT_AIMS_COMMAND).
